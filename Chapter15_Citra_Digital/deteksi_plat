import cv2
import pytesseract
import matplotlib.pyplot as plt

# 1. ATUR JALUR TESSERACT OCR (Sesuaikan dengan lokasi instalasi di laptop Anda)
# Untuk Windows biasanya menggunakan jalur di bawah ini:
pytesseract.pytesseract.tesseract_cmd = r'C:\Program Files\Tesseract-OCR\tesseract.exe'

def detect_plate_number(image_path):
    # 2. Muat Gambar Asli
    image = cv2.imread(image_path)
    if image is None:
        print(f"Error: Gambar '{image_path}' tidak ditemukan!")
        return

    # Tampilkan gambar asli menggunakan matplotlib
    plt.figure(figsize=(10, 5))
    plt.imshow(cv2.cvtColor(image, cv2.COLOR_BGR2RGB))
    plt.title("Gambar Asli")
    plt.axis('off')
    plt.show()

    # 3. Pra-pemrosesan Citra (Pre-processing)
    # Konversi gambar ke skala abu-abu (Grayscale)
    gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)

    # Terapkan Gaussian Blur untuk menghilangkan noise/derau
    blurred = cv2.GaussianBlur(gray, (5, 5), 0)

    # Deteksi tepi menggunakan Canny Edge Detection untuk menyorot kontur pelat
    edges = cv2.Canny(blurred, 100, 200)

    # 4. Mencari Kontur Pelat Nomor
    # Temukan semua kontur pada gambar hasil deteksi tepi
    contours, _ = cv2.findContours(edges.copy(), cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

    # Urutkan kontur berdasarkan luas area dari yang terbesar ke terkecil
    contours = sorted(contours, key=cv2.contourArea, reverse=True)

    plate_contour = None
    for contour in contours:
        # Perkiraan kontur menjadi bentuk poligon
        epsilon = 0.02 * cv2.arcLength(contour, True)
        approx = cv2.approxPolyDP(contour, epsilon, True)

        # Periksa apakah kontur memiliki 4 simpul (karakteristik persegi panjang pelat nomor)
        if len(approx) == 4:
            plate_contour = approx
            break

    # 5. Segmentasi dan Ekstraksi Teks (OCR)
    if plate_contour is not None:
        # Dapatkan koordinat kotak pembatas dari kontur pelat nomor
        x, y, w, h = cv2.boundingRect(plate_contour)
        
        # Potong (crop) area pelat nomor dari gambar grayscale
        plate_image = gray[y:y + h, x:x + w]

        # Terapkan ambang batas (Thresholding OTSU) untuk membinarisasikan gambar pelat (hitam-putih tegas)
        _, thresh = cv2.threshold(plate_image, 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)

        # Lakukan OCR menggunakan Pytesseract pada area pelat yang telah disegmentasi
        # Menggunakan konfigurasi --psm 8 (mengasumsikan gambar adalah satu baris teks/kata)
        plate_number = pytesseract.image_to_string(thresh, config='--psm 8')

        # Bersihkan karakter aneh yang tidak sengaja terbaca
        plate_number = "".join(c for c in plate_number if c.isalnum() or c.isspace()).strip()

        # 6. Menampilkan Hasil Akhir
        # Gambar kotak hijau pada foto asli di lokasi pelat yang terdeteksi
        cv2.rectangle(image, (x, y), (x + w, y + h), (0, 255, 0), 3)
        cv2.putText(image, plate_number, (x, y - 10), cv2.FONT_HERSHEY_SIMPLEX, 1, (0, 255, 0), 2)

        # Tampilkan hasil akhir
        plt.figure(figsize=(10, 5))
        plt.imshow(cv2.cvtColor(image, cv2.COLOR_BGR2RGB))
        plt.title(f"Pelat Terdeteksi: {plate_number}")
        plt.axis('off')
        plt.show()

        print(f"Hasil Pembacaan Teks Plat Nomor: {plate_number}")
    else:
        print("Plat nomor tidak berhasil ditemukan atau kontur segi empat tidak terdeteksi.")

# Memanggil fungsi program dengan file sampel Anda
detect_plate_number('plat_nomor.jpg')